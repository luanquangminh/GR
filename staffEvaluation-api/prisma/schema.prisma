generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String?    @map("password_hash")
  provider     String     @default("local")
  microsoftId  String?    @unique @map("microsoft_id")
  tokenVersion Int        @default(0) @map("token_version")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  profile      Profile?
  roles        UserRole[]

  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  staffId   Int?     @unique @map("staff_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  staff     Staff?   @relation(fields: [staffId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      AppRole
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model OrganizationUnit {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  groups    Group[]
  staff     Staff[]

  @@map("organizationunits")
}

model Staff {
  id                  Int               @id @default(autoincrement())
  name                String
  homeEmail           String?           @map("emailh")
  schoolEmail         String?           @unique @map("emails")
  staffcode           String            @unique
  gender              Gender?           @map("sex")
  birthday            DateTime?
  mobile              String?
  academicrank        String?
  academicdegree      String?
  position            String?
  isPartyMember       Boolean           @default(false) @map("is_party_member")

  organizationunitid  Int?              @map("organizationunitid")
  avatar              String?           @map("avatar")
  bidv                String?
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  evaluationsGiven    Evaluation[]      @relation("reviewer")
  evaluationsReceived Evaluation[]      @relation("evaluatee")
  profile             Profile?
  organizationUnit    OrganizationUnit? @relation(fields: [organizationunitid], references: [id], onDelete: SetNull)
  staffGroups         Staff2Group[]

  @@index([organizationunitid])
  @@map("staff")
}

model Group {
  id                 Int               @id @default(autoincrement())
  name               String
  organizationunitid Int?              @map("organizationunitid")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  evaluations        Evaluation[]
  organizationUnit   OrganizationUnit? @relation(fields: [organizationunitid], references: [id], onDelete: SetNull)
  staffGroups        Staff2Group[]
  subjects           Subject[]

  @@index([organizationunitid])
  @@map("groups")
}

model Staff2Group {
  id      Int   @id @default(autoincrement())
  staffid Int
  groupid Int
  group   Group @relation(fields: [groupid], references: [id], onDelete: Cascade)
  staff   Staff @relation(fields: [staffid], references: [id], onDelete: Cascade)

  @@unique([staffid, groupid])
  @@index([staffid])
  @@index([groupid])
  @@map("staff2groups")
}

model Question {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  evaluations Evaluation[]

  @@map("questions")
}

model Subject {
  id        Int      @id @default(autoincrement())
  subjectid String?
  name      String?
  groupid   Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  group     Group?   @relation(fields: [groupid], references: [id])

  @@map("subjects")
}

model EvaluationPeriod {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime         @map("start_date")
  endDate     DateTime         @map("end_date")
  status      PeriodStatus     @default(draft)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  evaluations Evaluation[]

  @@map("evaluation_periods")
}

model Evaluation {
  id           Int              @id @default(autoincrement())
  reviewerid   Int
  evaluateeid  Int              @map("evaluatee_id")
  groupid      Int
  questionid   Int
  periodid     Int              @map("periodid")
  point        Float            @default(0)
  createdAt    DateTime         @default(now()) @map("created_at")
  modifieddate DateTime         @default(now()) @updatedAt @map("modifieddate")
  group        Group            @relation(fields: [groupid], references: [id], onDelete: Cascade)
  question     Question         @relation(fields: [questionid], references: [id], onDelete: Cascade)
  reviewer     Staff            @relation("reviewer", fields: [reviewerid], references: [id], onDelete: Cascade)
  evaluatee    Staff            @relation("evaluatee", fields: [evaluateeid], references: [id], onDelete: Cascade)
  period       EvaluationPeriod @relation(fields: [periodid], references: [id], onDelete: Cascade)

  @@unique([reviewerid, evaluateeid, groupid, questionid, periodid], name: "reviewer_evaluatee_group_question_period")
  @@index([reviewerid])
  @@index([evaluateeid])
  @@index([groupid])
  @@index([questionid])
  @@index([periodid])
  @@index([reviewerid, periodid])
  @@index([evaluateeid, periodid])
  @@index([evaluateeid, groupid, periodid])
  @@map("evaluations")
}


enum AppRole {
  admin
  moderator
  user
}

enum Gender {
  male
  female

  @@map("gender")
}

enum PeriodStatus {
  draft
  active
  closed

  @@map("period_status")
}
